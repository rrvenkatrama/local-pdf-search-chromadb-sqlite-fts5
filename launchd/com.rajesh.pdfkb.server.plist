<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Search service (server.py) as a launchd user agent.

  Installed by install.sh into ~/Library/LaunchAgents/ with the
  __PROJECT_ROOT__ placeholders replaced by the real project path.

  RunAtLoad + KeepAlive = starts at login and is restarted automatically
  if it ever crashes, so http://localhost:8130/ is always available.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rajesh.pdfkb.server</string>

    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_ROOT__/venv/bin/python</string>
        <string>__PROJECT_ROOT__/server.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_ROOT__</string>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- Wait 5s between restart attempts (e.g. if the port is briefly busy). -->
    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>__PROJECT_ROOT__/data/server.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_ROOT__/data/server.log</string>
</dict>
</plist>
